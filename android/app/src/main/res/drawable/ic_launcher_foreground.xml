<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="72dp" android:height="72dp" />
            <stroke android:width="4dp" android:color="@color/ic_launcher_teal" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <size android:width="6dp" android:height="46dp" />
            <solid android:color="@color/ic_launcher_teal" />
        </shape>
    </item>
    <item android:gravity="center">
        <rotate android:fromDegrees="90">
            <shape android:shape="rectangle">
                <size android:width="6dp" android:height="46dp" />
                <solid android:color="@color/ic_launcher_teal" />
            </shape>
        </rotate>
    </item>
    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="20dp" android:height="20dp" />
            <solid android:color="@color/ic_launcher_orange" />
        </shape>
    </item>
    <item android:gravity="center_horizontal|top" android:top="26dp">
        <shape android:shape="rectangle">
            <size android:width="24dp" android:height="4dp" />
            <solid android:color="@color/ic_launcher_teal" />
        </shape>
    </item>
    <item android:gravity="center_horizontal|bottom" android:bottom="26dp">
        <shape android:shape="rectangle">
            <size android:width="24dp" android:height="4dp" />
            <solid android:color="@color/ic_launcher_teal" />
        </shape>
    </item>
    <item android:gravity="left|center_vertical" android:left="26dp">
        <shape android:shape="rectangle">
            <size android:width="4dp" android:height="24dp" />
            <solid android:color="@color/ic_launcher_teal" />
        </shape>
    </item>
    <item android:gravity="right|center_vertical" android:right="26dp">
        <shape android:shape="rectangle">
            <size android:width="4dp" android:height="24dp" />
            <solid android:color="@color/ic_launcher_teal" />
        </shape>
    </item>
</layer-list>
